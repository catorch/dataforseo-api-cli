{
  "name": "dataforseo-api-cli",
  "version": "0.1.0",
  "description": "Zero-dependency CLI for the DataForSEO API: keywords, SERP, backlinks, on-page audits, DataForSEO Labs, and AI/LLM visibility endpoints.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catorch/dataforseo-api-cli.git"
  },
  "keywords": [
    "dataforseo",
    "dataforseo-api",
    "seo",
    "seo-api",
    "keyword-research",
    "keyword-volume",
    "serp",
    "google-serp",
    "backlinks",
    "llm",
    "ai-optimization",
    "rest-api",
    "cli",
    "pi-package",
    "agent-skill"
  ],
  "bin": {
    "d4s": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "registry.json",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.mjs",
    "prepublishOnly": "bun run build",
    "extract": "node extract.mjs > registry.json",
    "test": "node dist/main.js list | head"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "skills": [
      "skills/dataforseo"
    ]
  },
  "devDependencies": {
    "dataforseo-mcp-server": "2.9.9"
  }
}
