{
  "name": "dataforseo-cli",
  "version": "0.1.0",
  "description": "Zero-dependency CLI for the full DataForSEO API (84 endpoints: keywords, SERP, backlinks, on-page, LLM/AI mentions, more). Direct REST calls — no MCP server required. Works as a standalone CLI and as a pi/Codex agent skill.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "dataforseo",
    "seo",
    "keyword-research",
    "serp",
    "backlinks",
    "llm",
    "ai-optimization",
    "cli",
    "pi-package",
    "agent-skill"
  ],
  "bin": {
    "d4s": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "registry.json",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.mjs",
    "prepublishOnly": "bun run build",
    "extract": "node extract.mjs > registry.json",
    "test": "node dist/main.js list | head"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "skills": ["skills/dataforseo"]
  }
}
